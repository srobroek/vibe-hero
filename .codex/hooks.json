{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/mcp-repomix/scripts/repomix-refresh-snapshot.sh",
            "async": true,
            "timeout": 30,
            "if": "Bash(git switch -c*)"
          }
        ],
        "_apm_source": "mcp-repomix"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/mcp-repomix/scripts/repomix-refresh-snapshot.sh",
            "async": true,
            "timeout": 30,
            "if": "Bash(git switch --create*)"
          }
        ],
        "_apm_source": "mcp-repomix"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/mcp-repomix/scripts/repomix-refresh-snapshot.sh",
            "async": true,
            "timeout": 30,
            "if": "Bash(git checkout -b*)"
          }
        ],
        "_apm_source": "mcp-repomix"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/mcp-repomix/scripts/repomix-refresh-snapshot.sh",
            "async": true,
            "timeout": 30,
            "if": "Bash(git checkout -B*)"
          }
        ],
        "_apm_source": "mcp-repomix"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/mcp-repomix/scripts/repomix-refresh-snapshot.sh",
            "async": true,
            "timeout": 30,
            "if": "Bash(git worktree add*)"
          }
        ],
        "_apm_source": "mcp-repomix"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/mcp-repomix/scripts/repomix-refresh-snapshot.sh",
            "async": true,
            "timeout": 30,
            "if": "Bash(git merge*)"
          }
        ],
        "_apm_source": "mcp-repomix"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/mcp-repomix/scripts/repomix-refresh-snapshot.sh",
            "async": true,
            "timeout": 30,
            "if": "Bash(git pull*)"
          }
        ],
        "_apm_source": "mcp-repomix"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/mcp-repomix/scripts/repomix-refresh-snapshot.sh",
            "async": true,
            "timeout": 30,
            "if": "Bash(git rebase*)"
          }
        ],
        "_apm_source": "mcp-repomix"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/speckit/scripts/speckit-task-commit-check.sh",
            "if": "Bash(git commit*)"
          }
        ],
        "_apm_source": "speckit"
      },
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/speckit/scripts/speckit-task-issue-sync.sh"
          }
        ],
        "_apm_source": "speckit"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/code-intelligence/scripts/reindex-after-commit.sh",
            "if": "Bash(git commit*)"
          }
        ],
        "_apm_source": "code-intelligence"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "apply_patch|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/agent-coder/scripts/coder-delegation-reminder.sh"
          }
        ],
        "_apm_source": "agent-coder"
      }
    ]
  }
}
