{
  "name": "@vibe-hero/server",
  "version": "0.13.2",
  "description": "MCP server engine for the vibe-hero adaptive-learning plugin — not used standalone; install the vibe-hero Claude Code plugin, which launches this and ships the skills + hook.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-code",
    "codex",
    "learning",
    "quiz",
    "adaptive-learning",
    "agentic-coding",
    "education"
  ],
  "author": "Sjors Robroek",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/srobroek/vibe-hero.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/srobroek/vibe-hero#readme",
  "bugs": {
    "url": "https://github.com/srobroek/vibe-hero/issues"
  },
  "private": false,
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "vibe-hero": "dist/cli/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm run gen-manifest && tsc -p tsconfig.json && pnpm run copy-assets",
    "gen-manifest": "node scripts/gen-manifest.mjs",
    "copy-assets": "node -e \"const{cpSync,existsSync,mkdirSync,readdirSync}=require('node:fs');const path=require('node:path');function cp(s,d){if(existsSync(s)){mkdirSync(d,{recursive:true});cpSync(s,d,{recursive:true,filter:p=>!p.endsWith('.ts')});}}cp('src/catalog/bundled','dist/catalog/bundled');const root=path.resolve('../..');const contentRoot=path.join(root,'content');if(existsSync(contentRoot)){readdirSync(contentRoot,{withFileTypes:true}).filter(e=>e.isDirectory()).map(e=>e.name).forEach(cls=>{const s=path.join(contentRoot,cls);const dDist=path.join('dist','catalog','bundled',cls);mkdirSync(dDist,{recursive:true});cpSync(s,dDist,{recursive:true});const dSrc=path.join('src','catalog','bundled',cls);mkdirSync(dSrc,{recursive:true});cpSync(s,dSrc,{recursive:true});});}\"",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "js-yaml": "^4.1.0",
    "pino": "^10.3.1",
    "proper-lockfile": "^4.1.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
