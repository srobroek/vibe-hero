{
  "name": "@vibe-hero/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run copy-assets",
    "copy-assets": "node -e \"const{cpSync,existsSync}=require('node:fs');const s='src/catalog/bundled';const d='dist/catalog/bundled';if(existsSync(s))cpSync(s,d,{recursive:true,filter:p=>!p.endsWith('.ts')});\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "js-yaml": "^4.1.0",
    "proper-lockfile": "^4.1.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
